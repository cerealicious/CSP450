!
vlan 231
    name Catalan_LAN
vlan 329
    name Sabra_LAN
!
interface vlan 231
    ip address 172.16.57.193/26
    ip ospf 1 area 0
!
interface vlan 329
    ip address 172.16.81.193/26
    ip ospf 1 area 0
!
interface 1/1/3
    no shutdown
    routing
    description Uplink_Trunk_To_2530
    vlan trunk allowed 231,329
!
interface 1/1/4
    no shutdown
    routing
    description Catalan_Router_WAN
    ip address 192.168.3.157/30
    ip ospf 1 area 0
!
interface 1/1/5
    no shutdown
    routing
    description Sabra_Router_WAN
    ip address 192.168.3.101/30
    ip ospf 1 area 0
!
router ospf 1
    router-id 231.1.1.1
!
dhcp-server vrf default
    pool pool_231
        range 172.16.57.194 172.16.57.253
        default-router 172.16.57.193
        dns-server 10.101.100.21
        static-bind ip 172.16.57.254 mac [YOUR_SERVER_MAC_HERE]
        exit
    pool pool_329
        range 172.16.81.194 172.16.81.253
        default-router 172.16.81.193
        dns-server 10.101.100.21
        static-bind ip 172.16.81.254 mac [SABRA_SERVER_MAC_HERE]
        exit
    no shutdown
!
